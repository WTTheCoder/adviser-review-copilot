generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SourceRecordType {
  LEGACY_CRM
  ANNUAL_REVIEW
  ADVISER_MEETING_NOTE
}

enum LifecycleStatus {
  CURRENT
  SUPERSEDED
  NEEDS_CONFIRMATION
  REQUIRES_ADVISER_APPROVAL
}

enum DecisionType {
  CONFIRM
  LEAVE_UNVERIFIED
  APPROVE
  KEEP_CURRENT
}

enum WorkflowRunStatus {
  PREPARING
  PREPARED
  FAILED
}

enum WorkflowStepStatus {
  COMPLETE
  ESCALATED
  FAILED
}

model Client {
  id               String            @id
  name             String
  adviserName      String
  reviewYear       Int
  reviewStatus     String
  mutationEpoch    Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sourceRecords    SourceRecord[]
  clientFacts      ClientFact[]
  adviserDecisions AdviserDecision[]
  workflowRuns     WorkflowRun[]
}

model SourceRecord {
  id              String           @id
  clientId        String
  type            SourceRecordType
  title           String
  observedAt      DateTime
  summary         String
  content         Json
  lifecycleStatus LifecycleStatus
  createdAt       DateTime         @default(now())
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  facts           ClientFact[]     @relation("LegacyFactSource")
  officialFacts   ClientFact[]     @relation("OfficialFactSource")
  previousFacts   ClientFact[]     @relation("PreviousFactSource")
  candidateFacts  ClientFact[]     @relation("CandidateFactSource")
  candidateDecisions AdviserDecision[] @relation("DecisionCandidateSource")
  officialBeforeDecisions AdviserDecision[] @relation("DecisionOfficialBeforeSource")
  resultingOfficialDecisions AdviserDecision[] @relation("DecisionResultingOfficialSource")

  @@index([clientId])
}

model ClientFact {
  id               String            @id
  clientId         String
  field            String
  officialValue    String
  candidateValue   String?
  previousValue    String?
  sourceRecordId   String
  observedAt       DateTime
  officialSourceRecordId String
  officialObservedAt     DateTime
  previousSourceRecordId String?
  previousObservedAt     DateTime?
  candidateSourceRecordId String?
  candidateObservedAt     DateTime?
  candidateEvidence       String?
  confidence       String
  lifecycleStatus  LifecycleStatus
  explanation      String
  revision         Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sourceRecord     SourceRecord      @relation("LegacyFactSource", fields: [sourceRecordId], references: [id])
  officialSourceRecord SourceRecord  @relation("OfficialFactSource", fields: [officialSourceRecordId], references: [id])
  previousSourceRecord SourceRecord? @relation("PreviousFactSource", fields: [previousSourceRecordId], references: [id])
  candidateSourceRecord SourceRecord? @relation("CandidateFactSource", fields: [candidateSourceRecordId], references: [id])
  adviserDecisions AdviserDecision[]

  @@index([clientId])
  @@index([sourceRecordId])
  @@index([officialSourceRecordId])
  @@index([previousSourceRecordId])
  @@index([candidateSourceRecordId])
}

model AdviserDecision {
  id           String       @id
  clientId     String
  factId       String
  decisionType DecisionType
  note         String?
  actor        String?
  candidateValue String?
  candidateSourceRecordId String?
  candidateObservedAt DateTime?
  candidateEvidence String?
  officialValueBefore String?
  officialSourceRecordIdBefore String?
  officialObservedAtBefore DateTime?
  resultingOfficialValue String?
  resultingOfficialSourceRecordId String?
  resultingOfficialObservedAt DateTime?
  createdAt    DateTime     @default(now())
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fact         ClientFact   @relation(fields: [factId], references: [id], onDelete: Cascade)
  candidateSourceRecord SourceRecord? @relation("DecisionCandidateSource", fields: [candidateSourceRecordId], references: [id], onDelete: Restrict)
  officialSourceRecordBefore SourceRecord? @relation("DecisionOfficialBeforeSource", fields: [officialSourceRecordIdBefore], references: [id], onDelete: Restrict)
  resultingOfficialSourceRecord SourceRecord? @relation("DecisionResultingOfficialSource", fields: [resultingOfficialSourceRecordId], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([factId])
  @@index([candidateSourceRecordId])
  @@index([officialSourceRecordIdBefore])
  @@index([resultingOfficialSourceRecordId])
}

model WorkflowRun {
  id          String            @id
  clientId    String
  status      WorkflowRunStatus
  startedAt   DateTime          @default(now())
  completedAt DateTime?
  client      Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  steps       WorkflowStep[]

  @@index([clientId])
}

model WorkflowStep {
  id            String             @id
  workflowRunId String
  sequence      Int
  label         String
  status        WorkflowStepStatus
  detail        String?
  workflowRun   WorkflowRun        @relation(fields: [workflowRunId], references: [id], onDelete: Cascade)

  @@index([workflowRunId])
}
